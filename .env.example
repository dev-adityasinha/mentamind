# Database
DATABASE_URL=postgresql://mentamind:mentamind_dev@localhost:5432/mentamind
DATABASE_URL_TEST=postgresql://mentamind_test:mentamind_test@localhost:5433/mentamind_test

# Auth
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_REFRESH_SECRET=change-me-too-use-different-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption (32-byte hex key for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mentamind

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
