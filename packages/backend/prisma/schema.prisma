generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  VOLUNTEER
  ADMIN
  DONOR
  HOSPITAL
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum RequestStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  MATCHING
  MATCHED
  IN_PROGRESS
  FULFILLED
  CANCELLED
  REJECTED
}

enum MedicineRequestStatus {
  DRAFT
  PENDING_OCR
  OCR_COMPLETE
  PENDING_REVIEW
  APPROVED
  DISPATCHED
  DELIVERED
  CANCELLED
  REJECTED
}

enum UrgencyLevel {
  CRITICAL
  URGENT
  NORMAL
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  phone             String
  role              Role
  identityVerified  Boolean   @default(false)
  maskedAadhaarRef  String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient           Patient?
  donor             Donor?
  hospital          Hospital?
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@index([email])
  @@index([role])
}

model Patient {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  bloodGroup       BloodGroup?
  medicalNotes     String?
  address          String?
  emergencyContact String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bloodRequests    BloodRequest[]
  medicineRequests MedicineRequest[]
}

model Donor {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id])
  bloodGroup       BloodGroup
  lastDonationDate DateTime?
  isAvailable      Boolean    @default(true)
  latitude         Float?
  longitude        Float?
  totalDonations   Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([bloodGroup, isAvailable])
  @@index([isAvailable])
}

model Hospital {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  hospitalName String
  address      String
  phone        String
  latitude     Float?
  longitude    Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bloodRequests BloodRequest[]
}

model BloodRequest {
  id            String        @id @default(uuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  hospitalId    String?
  hospital      Hospital?     @relation(fields: [hospitalId], references: [id])
  bloodGroup    BloodGroup
  unitsNeeded   Int
  urgency       UrgencyLevel  @default(NORMAL)
  status        RequestStatus @default(DRAFT)
  notes         String?
  matchedDonors Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([bloodGroup, status])
}

model MedicineRequest {
  id                  String                @id @default(uuid())
  patientId           String
  patient             Patient               @relation(fields: [patientId], references: [id])
  prescriptionFileKey String?
  ocrSuggestions      Json?
  adminReviewedData   Json?
  status              MedicineRequestStatus @default(DRAFT)
  reviewedBy          String?
  reviewedAt          DateTime?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
