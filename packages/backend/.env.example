# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mentamind:mentamind_dev@localhost:5432/mentamind

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_64_char_hex_jwt_secret_here
JWT_REFRESH_SECRET=your_64_char_hex_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ─── MinIO / S3 File Storage ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mentamind

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3002
