# Postgres
POSTGRES_USER=mentamind
POSTGRES_PASSWORD=mentamind
POSTGRES_DB=mentamind
DATABASE_URL=postgresql+asyncpg://mentamind:mentamind@localhost:5432/mentamind

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# CORS: comma-separated frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# Frontend base URL (used in invitation emails, etc.)
FRONTEND_URL=http://localhost:3000

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application-layer AES-256-GCM field encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change-me-in-production

# Email (SMTP via Gmail - use a Gmail App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply.mentamind@gmail.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply.mentamind@gmail.com

# SAML 2.0 SSO (leave empty to disable)
SAML_STRICT=True
SAML_DEBUG=False
SAML_SP_ENTITY_ID=mentamind-sp
SAML_SP_ACS_URL=http://localhost:8000/auth/saml/acs
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_X509_CERT=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
